{
  "name": "chrome-cookies-tab",
  "private": true,
  "version": "3.3.1",
  "type": "module",
  "description": "Easy cookies management via a dedicated tab in Developer Tools",
  "license": "MIT",
  "scripts": {
    "dev": "vite build --watch --mode development",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "overrides": {
    "rollup": "^4.60.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.0",
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "preact": "^10.29.2",
    "prettier": "^3.8.4",
    "sass": "^1.101.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "valibot": "^1.4.1"
  },
  "allowScripts": {
    "@parcel/watcher@2.5.6": true,
    "fsevents@2.3.3": true
  }
}
