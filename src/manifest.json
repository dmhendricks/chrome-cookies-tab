{
   "manifest_version": 3,
   "name": "Cookie Tab in DevTools",
   "short_name": "Cookie Tab",
   "version": "2.2.0",
   "devtools_page": "src/devtools/devtools-page.html",
   "description": "Add a tab to DevTools for easy cookies management",
   "author": "Daniel M. Hendricks",
   "homepage_url": "https://github.com/dmhendricks/chrome-cookie-tab",
   "icons": {
      "16": "cookie-16.png",
      "32": "cookie-32.png",
      "48": "cookie-48.png",
      "128": "cookie-128.png"
   },
   "background": {
      "service_worker": "src/background.ts",
      "type": "module"
   },
   "minimum_chrome_version": "120",
   "permissions": [
     "cookies",
     "webNavigation"
   ],
   "host_permissions": [
     "*://*/*"
   ]
}
