{
   "background": {
      "service_worker": "src/background.ts",
      "type": "module"
   },
   "devtools_page": "src/devtools/devtools-page.html",
   "description": "Missing cookie manager for Google Chrome. Edit and create cookies right in the Developer Tools.",
   "homepage_url": "https://github.com/dmhendricks/chrome-cookie-tab",
   "icons": {
      "128": "store-icon-128.png"
   },
   "manifest_version": 3,
   "minimum_chrome_version": "116",
   "name": "Cookie Tab in DevTools",
   "permissions": [
     "cookies",
     "tabs",
     "webNavigation"
   ],
   "host_permissions": [
     "*://*/*"
   ],
   "web_accessible_resources": [
     {
       "resources": ["src/panel/panel.html"],
       "matches": ["<all_urls>"]
     }
   ],
   "version": "2.1.0"
}
