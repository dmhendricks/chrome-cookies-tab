{
   "manifest_version": 3,
   "name": "__MSG_extName__",
   "short_name": "__MSG_extShortName__",
   "version": "3.2.0",
   "default_locale": "en",
   "devtools_page": "src/devtools/devtools-page.html",
   "description": "__MSG_extDescription__",
   "author": "Daniel M. Hendricks",
   "homepage_url": "https://github.com/dmhendricks/chrome-cookies-tab",
   "icons": {
      "16": "cookie-16.png",
      "32": "cookie-32.png",
      "48": "cookie-48.png",
      "128": "cookie-128.png"
   },
   "background": {
      "service_worker": "src/background.ts",
      "type": "module"
   },
   "minimum_chrome_version": "120",
   "permissions": [
     "cookies",
     "storage",
     "webNavigation"
   ],
   "host_permissions": [
     "*://*/*"
   ]
}
